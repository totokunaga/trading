//@version=6
indicator("Spike Mean Reversion", overlay=false)

bbLength = input.int(20, "BB Lookback")
bbMult = input.float(2.25, "BB Sigma")
rsiLength = input.int(14, "RSI Lookback")
volLength = input.int(14, "Volume Ratio Lookback")
atrLength = input.int(14, "ATR Ratio Lookback")
volThreshold = input.float(1.75, "Volume Ratio Threshold")
atrThreshold = input.float(3.0, "ATR Ratio Threshold")

bbBasis = ta.sma(close, bbLength)
bbDev = bbMult * ta.stdev(close, bbLength)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev
pctB = (close - bbLower) / (bbUpper - bbLower)

rsi = ta.rsi(close, rsiLength)

avgVolume = ta.sma(volume, volLength)
volRatio = avgVolume > 0 ? volume / avgVolume : 0.0

atrValue = ta.atr(atrLength)
barRange = high - low
atrRatio = atrValue > 0 ? barRange / atrValue : 0.0

score = 0
isUpper = false
isLower = false

if pctB >= 1.0
    isUpper := true
    score := 1
    if rsi >= 70.0
        score := 2
        if volRatio >= volThreshold
            score += 1
        if atrRatio >= atrThreshold
            score += 1
else if pctB <= 0.0
    isLower := true
    score := 1
    if rsi <= 30.0
        score := 2
        if volRatio >= volThreshold
            score += 1
        if atrRatio >= atrThreshold
            score += 1

plotValue = score
displayValue = plotValue == 0 ? 0.3 : plotValue

color barColor = na
if score == 0
    barColor := color.new(color.gray, 60)
else if isUpper
    barColor := switch score
        1 => color.new(color.red, 70)
        2 => color.new(color.red, 50)
        3 => color.new(color.red, 25)
        => color.red
else
    barColor := switch score
        1 => color.new(color.blue, 70)
        2 => color.new(color.blue, 50)
        3 => color.new(color.blue, 25)
        => color.blue

plot(displayValue, "Spike Score", style=plot.style_histogram, color=barColor, linewidth=4)
hline(0, "Zero", color=color.gray, linestyle=hline.style_solid)
hline(4, "", color=color.new(color.gray, 100))

alertcondition(score >= 3 and isUpper, "Bullish Spike (3+)", "Bullish spike score >= 3")
alertcondition(score >= 3 and isLower, "Bearish Spike (3+)", "Bearish spike score >= 3")
alertcondition(score >= 3, "Any Spike (3+)", "Spike score >= 3")

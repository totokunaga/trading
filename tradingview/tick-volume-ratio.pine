//@version=6
indicator("Tick Volume Ratio", overlay=false)

lookback = input.int(20, "Lookback", minval=1)
trendLookback = input.int(3, "Trend Lookback", minval=2)
highThreshold = input.float(1.5, "High Volume Threshold", minval=1.0)
lowThreshold = input.float(0.8, "Low Volume Threshold", maxval=1.0)

avgVolume = ta.sma(volume, lookback)
ratio = avgVolume > 0 ? volume / avgVolume : 0.0

isClimbing = true
isDeclining = true
for i = 1 to trendLookback - 1
    if ratio[i - 1] <= ratio[i]
        isClimbing := false
    if ratio[i - 1] >= ratio[i]
        isDeclining := false

lineColor = isClimbing ? color.blue : isDeclining ? color.red : color.navy

plot(ratio, "Volume Ratio", color=lineColor, linewidth=1)
plot(ratio, "Dot", color=lineColor, style=plot.style_circles, linewidth=1)

hHigh = hline(highThreshold, "High Threshold", color=color.new(color.red, 60), linestyle=hline.style_dotted)
hBase = hline(1.0, "Baseline", color=color.gray, linestyle=hline.style_solid)
hLow = hline(lowThreshold, "Low Threshold", color=color.new(color.blue, 60), linestyle=hline.style_dotted)
fill(hBase, hHigh, color=color.new(color.blue, 90))
fill(hBase, hLow, color=color.new(color.red, 90))